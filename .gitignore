# ====================================================================
# ROAD ANOMALY DETECTOR - GIT IGNORE CONFIGURATION
# ====================================================================

# Ignore Python runtime cache folders
__pycache__/
*.py[cod]
*$py.class

# Ignore local virtual environments if a user sets one up
venv/
.venv/
env/
ENV/

# Ignore system-specific files (Mac and Windows background files)
.DS_Store
Thumbs.db

# Ignore local output files generated by running detect.py
# This ensures users don't accidentally upload their own test results
detected_anomaly.jpg
